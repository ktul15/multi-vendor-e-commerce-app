// Multi-Vendor E-Commerce App — Prisma Schema
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ========================
// Enums
// ========================

enum Role {
  CUSTOMER
  VENDOR
  ADMIN
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum NotificationType {
  ORDER_CONFIRMED
  ORDER_PROCESSING
  ORDER_SHIPPED
  ORDER_DELIVERED
  ORDER_CANCELLED
  ORDER_REFUNDED
  PROMO
}

enum PaymentStatus {
  PENDING
  PROCESSING
  SUCCEEDED
  FAILED
  REFUNDED
  CANCELLED
}

enum PaymentMethod {
  CARD
  CASH_ON_DELIVERY
  WALLET
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

// ISO 4217 currency codes supported by the platform
enum Currency {
  USD
  EUR
  GBP
  INR
  CAD
  AUD
}

// ========================
// Models
// ========================

model User {
  id         String   @id @default(uuid())
  name       String
  email      String   @unique
  password   String
  role       Role     @default(CUSTOMER)
  avatar     String?
  // FCM tokens are device-scoped; unique prevents duplicate registrations
  fcmToken   String?  @unique
  isVerified Boolean  @default(false)
  isBanned   Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relationships
  products      Product[]
  cart          Cart?
  addresses     Address[]
  orders        Order[]
  vendorOrders  VendorOrder[]    @relation("VendorOrders")
  notifications Notification[]
  reviews       Review[]
  wishlistItems WishlistItem[]
  promoUsages   PromoUsage[]

  @@map("users")
}

// ========================
// E-Commerce Models
// ========================

model Category {
  id       String     @id @default(uuid())
  name     String
  slug     String     @unique
  image    String?
  parentId String?
  parent   Category?  @relation("Subcategories", fields: [parentId], references: [id])
  children Category[] @relation("Subcategories")

  products Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("categories")
}

model Product {
  id          String  @id @default(uuid())
  vendorId    String
  categoryId  String
  name        String
  description String
  basePrice   Decimal  @db.Decimal(10, 2)
  images      String[]
  isActive    Boolean  @default(true)
  // Denormalized aggregate — must be updated atomically alongside Review writes
  avgRating   Decimal  @default(0.0) @db.Decimal(4, 2)
  reviewCount Int      @default(0)
  tags        String[]

  // Relationships
  vendor   User      @relation(fields: [vendorId], references: [id])
  category Category  @relation(fields: [categoryId], references: [id])
  variants      Variant[]
  reviews       Review[]
  wishlistItems WishlistItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([categoryId])
  @@index([vendorId])
  @@index([name])
  @@index([avgRating])
  @@index([reviewCount])
  @@map("products")
}

model Variant {
  id        String  @id @default(uuid())
  productId String
  size      String?
  color     String?
  price     Decimal @db.Decimal(10, 2)
  stock     Int     @default(0)
  sku       String  @unique

  // Relationships
  product    Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  cartItems  CartItem[]
  orderItems OrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId])
  @@map("variants")
}

// ========================
// Cart Models
// ========================

model Cart {
  id        String     @id @default(uuid())
  userId    String     @unique
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     CartItem[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@map("carts")
}

model CartItem {
  id        String   @id @default(uuid())
  cartId    String
  variantId String
  quantity  Int      @default(1)
  cart      Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  variant   Variant  @relation(fields: [variantId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([cartId, variantId])
  @@map("cart_items")
}

// ========================
// Address Model
// ========================

model Address {
  id        String   @id @default(uuid())
  userId    String
  fullName  String
  phone     String
  street    String
  city      String
  state     String
  country   String
  zipCode   String
  // Only one default per user — enforced in service layer via transaction
  isDefault Boolean  @default(false)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders    Order[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("addresses")
}

// ========================
// Order Models
// ========================

model Order {
  id          String  @id @default(uuid())
  orderNumber String  @unique
  userId      String
  addressId   String
  promoCodeId String?
  // Snapshot of the shipping address at time of order — prevents stale data if
  // the user edits their address later. addressId FK is kept for reference only.
  shippingAddress Json
  subtotal    Decimal @db.Decimal(10, 2)
  discount    Decimal @default(0) @db.Decimal(10, 2)
  tax         Decimal @default(0) @db.Decimal(10, 2)
  total       Decimal @db.Decimal(10, 2)
  notes              String?
  cancellationReason String?

  user         User          @relation(fields: [userId], references: [id])
  // onDelete: Restrict is the default; explicit here to document intent —
  // an address used in an order must not be deleted.
  address      Address       @relation(fields: [addressId], references: [id], onDelete: Restrict)
  promoCode    PromoCode?    @relation(fields: [promoCodeId], references: [id])
  promoUsage   PromoUsage?
  vendorOrders VendorOrder[]
  payment      Payment?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([createdAt])
  @@index([promoCodeId])
  @@map("orders")
}

// One VendorOrder per vendor per customer Order.
// Carries its own status so vendors can fulfill independently.
model VendorOrder {
  id       String      @id @default(uuid())
  orderId  String
  vendorId String
  status   OrderStatus @default(PENDING)
  subtotal Decimal     @db.Decimal(10, 2)

  order    Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  vendor   User        @relation("VendorOrders", fields: [vendorId], references: [id])
  items    OrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([orderId, vendorId])
  @@index([vendorId])
  @@index([status])
  @@map("vendor_orders")
}

model OrderItem {
  id            String  @id @default(uuid())
  vendorOrderId String
  variantId     String
  quantity      Int
  unitPrice     Decimal @db.Decimal(10, 2)
  totalPrice    Decimal @db.Decimal(10, 2)

  vendorOrder VendorOrder @relation(fields: [vendorOrderId], references: [id], onDelete: Cascade)
  // onDelete: Restrict — a variant that has been ordered cannot be deleted;
  // use isActive=false on the Variant for soft-deletion instead.
  variant     Variant     @relation(fields: [variantId], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([vendorOrderId])
  @@index([variantId])
  @@map("order_items")
}

// ========================
// Payment Model
// ========================

model Payment {
  id                    String        @id @default(uuid())
  orderId               String        @unique
  amount                Decimal       @db.Decimal(10, 2)
  currency              Currency      @default(USD)
  method                PaymentMethod
  status                PaymentStatus @default(PENDING)
  stripePaymentIntentId String?       @unique
  stripePaymentMethodId String?
  paidAt                DateTime?

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@map("payments")
}

// ========================
// Promo Code Model
// ========================

model PromoCode {
  id            String       @id @default(uuid())
  code          String       @unique
  discountType  DiscountType
  discountValue Decimal      @db.Decimal(10, 2)
  minOrderValue Decimal?     @db.Decimal(10, 2)
  maxDiscount   Decimal?     @db.Decimal(10, 2)
  usageLimit    Int?
  // usageCount increments must be done atomically in the service layer
  // (UPDATE ... WHERE usage_count < usage_limit) to prevent race conditions.
  usageCount    Int          @default(0)
  perUserLimit  Int?
  isActive      Boolean      @default(true)
  expiresAt     DateTime?
  orders        Order[]
  usages        PromoUsage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // @@index([code]) removed — @unique already creates a B-tree index on code
  @@index([isActive])
  @@map("promo_codes")
}

// ========================
// Promo Usage Tracking
// ========================

model PromoUsage {
  id          String @id @default(uuid())
  userId      String
  promoCodeId String
  orderId     String @unique

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Restrict: promo codes with usage records cannot be hard-deleted (audit safety)
  promoCode PromoCode @relation(fields: [promoCodeId], references: [id], onDelete: Restrict)
  order     Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)

  usedAt DateTime @default(now())

  @@unique([userId, orderId])
  @@index([userId, promoCodeId])
  @@map("promo_usages")
}

// ========================
// Notification Model
// ========================

model Notification {
  id     String           @id @default(uuid())
  userId String
  type   NotificationType
  title  String
  body   String
  data   Json?
  isRead Boolean          @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, isRead])
  @@index([userId, createdAt])
  @@map("notifications")
}

// ========================
// Review & Wishlist Models
// ========================

model Review {
  id        String   @id @default(uuid())
  userId    String
  productId String
  rating    Int
  comment   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([productId])
  @@index([productId, rating])
  @@map("reviews")
}

model WishlistItem {
  id        String   @id @default(uuid())
  userId    String
  productId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([userId])
  @@map("wishlist_items")
}
